# ================================================================
#  SC LuxScaleAI — .gitignore
#  Flask + Python backend  |  Vanilla JS / HTML frontend
#  Place this file at the project root: LuxScaleAI/.gitignore
# ================================================================

luxscale_app.log
uniformity_reports/
calculation_logs/
api/data/studies/*.json

# Local env (copy from .env.example)
.env
# Add these lines to your existing .gitignore:
gemini_config.json
gemini_snapshot.json

# ────────────────────────────────────────────────────────────────
#  STUDY DATA  (user-generated, never commit)
# ────────────────────────────────────────────────────────────────
api/data/studies/*.json
api/data/studies/!.gitignore

# IES photometric files (large binaries, serve from storage)
api/data/ies/
ies/
*.ies
*.IES

# Generated PDF reports
*.pdf
reports/

# Generated exports
*.dxf
*.stl


